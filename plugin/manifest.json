{
  "Name": "Home Ops Status",
  "Version": "1.0.0",
  "Author": "phew-blue",
  "Description": "Live Kubernetes cluster status for home-ops",
  "Category": "Home Ops",
  "CategoryIcon": "imgs/plugin-icon",
  "CodePath": "dist/plugin.js",
  "Icon": "imgs/plugin-icon",
  "UUID": "com.phewblue.homeops",
  "SDKVersion": 2,
  "Software": { "MinimumVersion": "6.4" },
  "OS": [{ "Platform": "windows", "MinimumVersion": "10" }],
  "Nodejs": { "Version": "20", "Debug": "enabled" },
  "Actions": [
    {
      "Name": "App Status",
      "UUID": "com.phewblue.homeops.status",
      "Icon": "imgs/status-icon",
      "Tooltip": "Shows live pod count, restarts, CPU and RAM",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/status-loading", "Title": "Loading...", "ShowTitle": true }]
    },
    {
      "Name": "Cluster Metric",
      "UUID": "com.phewblue.homeops.cluster",
      "Icon": "imgs/status-icon",
      "Tooltip": "Shows live cluster metric from kromgo",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/status-loading", "Title": "...", "ShowTitle": true }]
    },
    {
      "Name": "Node Status",
      "UUID": "com.phewblue.homeops.node",
      "Icon": "imgs/status-icon",
      "Tooltip": "Shows live Kubernetes node status",
      "Controllers": ["Keypad"],
      "States": [{ "Image": "imgs/status-loading", "Title": "...", "ShowTitle": true }]
    }
  ]
}
